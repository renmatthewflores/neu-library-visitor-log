rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: only @neu.edu.ph accounts ───────────────────────────
    function isNeuUser() {
      return request.auth != null
          && request.auth.token.email.matches(".*@neu\\.edu\\.ph");
    }

    function isAdmin() {
      return isNeuUser()
          && request.auth.token.email in ["jcesperanza@neu.edu.ph"];
    }

    // ─── Visitors collection ─────────────────────────────────────────
    match /visitors/{docId} {

      // Any authenticated @neu.edu.ph user can CREATE their own log entry.
      allow create: if isNeuUser()
                    && request.resource.data.uid == request.auth.uid;

      // Only admins can READ all visitor records.
      allow read: if isAdmin();

      // No one may UPDATE or DELETE through the client SDK.
      allow update, delete: if false;
    }

    // ─── Admin config (future use) ────────────────────────────────────
    match /adminConfig/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
  }
}
